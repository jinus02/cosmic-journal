# Supabase — supabase.com 에서 새 프로젝트 생성 후 Settings > API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # 서버 전용. 절대 클라이언트 노출 금지

# Gemini API — 지누스 .env 의 GEMINI_API_KEY_1..20 을 그대로 복사하거나 일부만 사용
# 키풀은 1부터 순차 탐색, 빈 슬롯은 건너뜀
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
# ... 필요한 만큼 추가 (1~20)

# 우주 시드 — 한 번 정하면 변경 금지. 변경 시 모든 기존 행성 좌표가 어긋남
COSMIC_UNIVERSE_SEED=cosmic-journal-2026

# Public site URL (OG 메타·공유 링크용)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
